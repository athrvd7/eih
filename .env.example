# ── Required ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── ChromaDB ───────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Storage ────────────────────────────────────────────────────────────────────
REPOS_DIR=/tmp/eih_repos
DB_PATH=./eih.db

# ── Limits ─────────────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=100
MAX_REPO_MB=500
MAX_FILES=500

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
